<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp"
    tools:context=".sample.ui.AgentChatActivity">

    <!-- Title -->
    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@null"
        android:contentDescription="Settings"
        android:padding="9dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_settings"
        app:tint="@color/mic_normal_icon" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Real-time Voice Conversation Demo"
        android:textColor="@color/text_subtitle"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@id/btnSettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTurnDetectionMode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="@id/tvSubtitle"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        tools:text="SOS: VAD  |  EOS: Semantic" />

    <!-- Log Section -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLog"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/bg_log_outer"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_default"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTurnDetectionMode">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_log_content"
            android:padding="12dp"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Transcript List and Agent Status -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTranscript"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toTopOf="@id/llControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_goneMarginBottom="88dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardLog">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/llCapabilityPanel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/bg_control_bar"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvCapabilityTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Capabilities"
                    android:textColor="@color/text_subtitle"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llManualTurnActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManualSos"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/selector_button_manual"
                        android:letterSpacing="0"
                        android:minWidth="0dp"
                        android:text="SOS"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="8dp"
                        app:elevation="0dp"
                        app:rippleColor="#33FFFFFF" />

                    <Space
                        android:id="@+id/manualActionDivider"
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnManualEos"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:background="@drawable/selector_button_manual"
                        android:letterSpacing="0"
                        android:minWidth="0dp"
                        android:text="EOS"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="8dp"
                        app:elevation="0dp"
                        app:rippleColor="#33FFFFFF" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llTranscriptHeader"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llCapabilityPanel">

                <LinearLayout
                    android:id="@+id/llAgentStatus"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot" />

                    <TextView
                        android:id="@+id/tvAgentStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Idle"
                        android:textColor="@color/state_idle"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Speaking" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llRealtimeDataToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_realtime_data_toggle"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/tvRealtimeDataToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Real-time Data"
                        android:textColor="@color/text_subtitle"
                        android:textSize="10sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchRealtimeData"
                        android:layout_width="36dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:checked="true"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:showText="false"
                        android:splitTrack="false"
                        android:textOff=""
                        android:textOn=""
                        android:thumb="@drawable/bg_switch_thumb"
                        app:track="@drawable/bg_switch_track" />
                </LinearLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTranscript"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingTop="2dp"
                android:scrollbars="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llTranscriptHeader" />

            <LinearLayout
                android:id="@+id/llInterruptPanel"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:paddingBottom="10dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInterrupt"
                    android:layout_width="128dp"
                    android:layout_height="38dp"
                    android:background="@drawable/selector_button_interrupt"
                    android:letterSpacing="0"
                    android:minWidth="0dp"
                    android:text="Interrupt"
                    android:textAllCaps="false"
                    android:textColor="@color/text_subtitle"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="8dp"
                    app:elevation="0dp"
                    app:rippleColor="#33FFFFFF" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Start Button -->
    <LinearLayout
        android:id="@+id/llStart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/selector_gradient_button"
            android:letterSpacing="0.02"
            android:text="Start Agent"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="8dp"
            app:elevation="0dp"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:id="@+id/llControls"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="42dp"
        android:paddingEnd="42dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMute"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_button_mute_selector"
            android:contentDescription="Mute/Unmute"
            android:padding="16dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_mic"
            app:tint="@color/mic_normal_icon" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnChat"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_button_mute_selector"
            android:contentDescription="Send chat message"
            android:padding="17dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_message_text"
            app:tint="@color/white" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnStop"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_button_mute_selector"
            android:contentDescription="Stop Agent"
            android:padding="16dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_close"
            app:tint="@color/error_red_light" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
