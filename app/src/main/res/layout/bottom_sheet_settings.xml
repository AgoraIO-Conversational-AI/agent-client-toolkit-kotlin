<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="360dp"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_title"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVersionInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/border_default" />

    <LinearLayout
        android:id="@+id/rowAgentId"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAgentIdLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agent ID"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAgentId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:ellipsize="middle"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnCopyAgentId"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_realtime_data_toggle"
            android:gravity="center"
            android:minWidth="56dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Copy"
            android:textColor="@color/text_subtitle"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/dividerAgentId"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_default"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/rowTurnSosDetection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTurnSosDetectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SOS"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/groupTurnSosDetection"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_turn_mode_group"
            android:orientation="horizontal"
            android:padding="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSosVad"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="VAD"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSosSemantic"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="Semantic"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSosManual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="Manual"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_default" />

    <LinearLayout
        android:id="@+id/rowTurnEosDetection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTurnEosDetectionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EOS"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/groupTurnEosDetection"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_turn_mode_group"
            android:orientation="horizontal"
            android:padding="2dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEosVad"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="VAD"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEosSemantic"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="Semantic"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEosManual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:checkable="true"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0"
                android:text="Manual"
                android:textAllCaps="false"
                android:textColor="@color/turn_mode_button_text"
                android:textSize="12sp"
                app:backgroundTint="@color/turn_mode_button_bg"
                app:cornerRadius="99dp"
                app:rippleColor="@color/turn_mode_button_ripple"
                app:strokeColor="@color/border_default"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_default" />

</LinearLayout>
