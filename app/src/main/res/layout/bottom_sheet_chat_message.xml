<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="16dp">

    <LinearLayout
        android:id="@+id/llChatHeader"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvChatSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chat"
            android:textColor="@color/text_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChatModeText"
            android:layout_width="82dp"
            android:layout_height="36dp"
            android:background="@drawable/selector_chat_mode_selected"
            android:letterSpacing="0"
            android:minWidth="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Text"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:backgroundTint="@null"
            app:cornerRadius="8dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_message_text"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="14dp"
            app:iconTint="@color/white"
            app:rippleColor="#33FFFFFF" />

        <Space
            android:layout_width="8dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChatModeImage"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:background="@drawable/selector_chat_mode_unselected"
            android:letterSpacing="0"
            android:minWidth="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="Image URL"
            android:textAllCaps="false"
            android:textColor="@color/text_subtitle"
            android:textSize="12sp"
            app:backgroundTint="@null"
            app:cornerRadius="8dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_image"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="14dp"
            app:iconTint="@color/text_subtitle"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llChatInputRow"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_message_input"
            android:hint="Type a message"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:minHeight="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="14sp"
            tools:text="Hello" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendChatMessage"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/selector_button_manual"
            android:letterSpacing="0"
            android:minWidth="0dp"
            android:text="Send"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="8dp"
            app:elevation="0dp"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>
</LinearLayout>
